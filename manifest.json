{
  "manifest_version": 3,
  "name": "LuminaRetouch for Higgsfield",
  "version": "1.0.0",
  "description": "Professional image editing controls injected directly into Higgsfield.ai - Generate optimized prompts for Nano Banana Pro",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://higgsfield.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://higgsfield.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

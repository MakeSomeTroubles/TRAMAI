# TRAMAI — API Keys
# Copy this file to .env.local and fill in your keys.
# The dev server (npm run dev:api) reads from .env.local

# Fal.ai — Image generation (Flux Pro / Flux Dev)
# Get your key at: https://fal.ai/dashboard/keys
# Format: <key_id>:<key_secret>
FAL_KEY=

# Google AI — Gemini (AD Assist prompt rewriting + image description)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# HuggingFace — Free fallback image generation (optional)
# Works without a token for public models (SDXL).
# With a token you get higher rate limits.
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=
